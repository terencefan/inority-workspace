{
  "name": "inority-workspace",
  "version": "1.0.0",
  "private": true,
  "description": "Workspace control-plane source repo for Codex assets, memory, and handbook tooling.",
  "workspaces": [
    "handbook"
  ],
  "scripts": {
    "codex:install:inority-reply": "bash ./skills/inority-reply/scripts/install.sh",
    "codex:uninstall:inority-reply": "bash ./skills/inority-reply/scripts/uninstall.sh",
    "codex:install:reply-format-hook": "bash ./skills/inority-reply/scripts/install.sh",
    "codex:uninstall:reply-format-hook": "bash ./skills/inority-reply/scripts/uninstall.sh",
    "codex:install:inority-memory": "node ./skills/inority-memory/scripts/install.mjs",
    "codex:uninstall:inority-memory": "node ./skills/inority-memory/scripts/uninstall.mjs",
    "codex:install:workspace-memory": "node ./skills/inority-memory/scripts/install.mjs",
    "codex:uninstall:workspace-memory": "node ./skills/inority-memory/scripts/uninstall.mjs",
    "codex:install": "npm run codex:install:inority-reply && npm run codex:install:inority-memory",
    "codex:uninstall": "npm run codex:uninstall:inority-memory && npm run codex:uninstall:inority-reply",
    "handbook:dev": "npm run dev --workspace handbook",
    "handbook:build": "npm run build --workspace handbook",
    "handbook:start": "npm run start --workspace handbook",
    "handbook:test": "npm run test --workspace handbook",
    "handbook:lint": "npm run lint --workspace handbook",
    "runbook:test": "node ./skills/runbook/tests/run.mjs",
    "slides:test": "node ./skills/inority-slides/tests/run.mjs",
    "spec:test": "node ./skills/write-spec/tests/run.mjs"
  }
}
