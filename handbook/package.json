{
  "name": "handbook",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "vite build --config vite.config.ts",
    "dev": "node scripts/dev.ts",
    "dev:site": "vite --config vite.config.ts --host 0.0.0.0",
    "dev:node": "node --watch src/index.ts",
    "install-hooks": "node scripts/install-git-hooks.ts",
    "lint": "eslint --config eslint.config.js src",
    "start": "node src/index.ts",
    "test": "node --test test/**/*.test.ts",
    "validate:markdown-links": "node scripts/validate-markdown-links.ts",
    "validate:sensitive-content": "node scripts/validate-sensitive-content.ts"
  },
  "dependencies": {
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@mui/icons-material": "^7.3.9",
    "@mui/material": "^7.3.9",
    "@mui/x-tree-view": "^8.27.2",
    "@viz-js/viz": "^3.25.0",
    "highlight.js": "^11.11.1",
    "markdown-it": "^14.1.1",
    "mermaid": "^11.13.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "svg-pan-zoom": "^3.6.2"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.0",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "vite": "^8.0.0"
  }
}
