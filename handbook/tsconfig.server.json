{
  "compilerOptions": {
    "target": "ES2022",
    "module": "CommonJS",
    "moduleResolution": "Node",
    "outDir": "build-server",
    "rootDir": ".",
    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true,
    "types": ["node"],
    "lib": ["ES2022"],
    "skipLibCheck": true,
    "strict": true
  },
  "include": ["server.ts", "src/**/*.d.ts"]
}
