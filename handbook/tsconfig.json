{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true,
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "types": ["node", "vite/client"],
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true
  },
  "include": ["server.ts", "vite.config.ts", "src/**/*.ts", "src/**/*.d.ts"]
}
